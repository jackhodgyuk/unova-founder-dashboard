# API
PORT=8080
DASHBOARD_URL=http://127.0.0.1:8080
FIVEM_API_KEY=change_this_fivem_secret

# Firebase dashboard login
# Public Firebase web config. The app has safe defaults for the FounderBot project,
# but these can be set explicitly if you rotate/recreate the Firebase web app.
FIREBASE_API_KEY=your_firebase_web_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_APP_ID=your_firebase_web_app_id
FIREBASE_MESSAGING_SENDER_ID=optional_sender_id
FIREBASE_STORAGE_BUCKET=optional_storage_bucket
FIREBASE_MEASUREMENT_ID=optional_measurement_id

# Discord management
DISCORD_GUILD_ID=your_discord_server_id
DISCORD_BOT_TOKEN=your_bot_token
DISCORD_BOT_DISPLAY_NAME=Unova Management
DISCORD_BOT_USER_ID=your_bot_application_id
DISCORD_BOT_ROLE_ID=optional_bot_role_id
DISCORD_LOG_CHANNEL_ID=staff_log_channel_id

# One Discord role controls bot commands and in-city /adminui access.
MANAGEMENT_ROLE_ID=your_management_role_id
MANAGEMENT_ROLE_NAME=optional_management_role_name_fallback

# Discord ticket ladder roles
FOUNDER_DISCORD_ID=your_founder_discord_user_id
FOUNDER_ROLE_ID=your_founder_role_id
OWNER_ROLE_ID=your_owner_role_id
CO_OWNER_ROLE_ID=your_co_owner_role_id
SERVER_MANAGER_ROLE_ID=your_server_manager_role_id
STAFF_MANAGER_ROLE_ID=your_staff_manager_role_id
SENIOR_STAFF_ROLE_ID=your_senior_staff_role_id
STAFF_ROLE_ID=your_staff_role_id
DEVELOPER_ROLE_ID=your_developer_role_id
HEAD_DEVELOPER_ROLE_ID=your_head_developer_role_id

# Tickets and role automation
DISCORD_TICKET_CATEGORY_ID=optional_ticket_category_id
DISCORD_TICKET_CATEGORY_NAME=tickets
TICKET_ACCESS_ROLE_IDS=optional_extra_ticket_role_ids
WHITELISTED_ROLE_ID=your_whitelisted_role_id
DISCORD_WHITELIST_CHANNEL_ID=optional_whitelist_channel_id
DISCORD_WHITELIST_CHANNEL_NAME=whitelist-management
DISCORD_BAN_ROLE_ID=your_banned_role_id
DISCORD_BAN_REMOVE_ROLE_IDS=roles_to_remove_when_banned
PRIORITY_ROLE_RULES=role_id:Queue Label:priority_points

# MySQL
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=unova_dashboard
